VITE_API_BASE_URL=/api
VITE_AES_KEY=replace-with-aes-key
VITE_HMAC_KEY=replace-with-hmac-key
VITE_DEV_LOGIN_IDENTITY=dev@cheersai.local
VITE_DEV_LOGIN_PASSWORD=123456

# Optional dev proxy targets (vite.config.ts)
VITE_AUTH_API_TARGET=http://localhost:8081
VITE_USER_API_TARGET=http://localhost:8082
VITE_FEEDBACK_API_TARGET=http://localhost:8083
VITE_PRODUCT_API_TARGET=http://localhost:8084
VITE_PLAN_API_TARGET=http://localhost:8085
VITE_AUDIT_API_TARGET=http://localhost:8087
