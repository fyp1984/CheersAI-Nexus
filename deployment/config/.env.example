#==============================================================================
# 环境变量配置说明
# 
# 生产环境敏感信息通过环境变量注入，不要硬编码在配置文件中
#==============================================================================

# 数据库连接
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=cheersai
DB_USER=nexus_app
DB_SCHEMA=nexus
DB_PASSWORD=your_postgresql_password_here

# Redis 连接（如果没有设置密码则留空）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 密钥（至少 32 字符）
JWT_SECRET=your_jwt_secret_key_here_must_be_at_least_32_characters
JWT_ISSUER=cheersai-nexus-uat
JWT_AUDIENCE=cheersai-nexus-web

# 阿里云短信配置
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=CheersAI
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# 应用端口（各服务独立）
# AUTH_PORT=8082
# USER_MANAGEMENT_PORT=8083
# FEEDBACK_PORT=8084
# PRODUCT_PORT=8085

# 日志级别
LOG_LEVEL=INFO

#==============================================================================
# 内测申请开通链路（UAT/PRO 建议显式配置）
#==============================================================================

# 是否启用审核通过后的自动开通（SSO + FileBay + Desktop回调）
BETA_PROVISION_ENABLED=true

# SSO 开通配置
SSO_API_URL=https://uat-sso.cheersai.cloud/api
SSO_PROVISION_OWNER=CheersAI
SSO_PROVISION_CLIENT_ID=replace-with-client-id
SSO_PROVISION_CLIENT_SECRET=replace-with-client-secret
SSO_PROVISION_DEFAULT_ROLE=desktop_team_admin

# FileBay 开通配置
FILEBAY_BASE_URL=https://uat-filebay.cheersai.cloud
FILEBAY_ADMIN_USERNAME=admin
FILEBAY_ADMIN_PASSWORD=replace-with-filebay-admin-password
FILEBAY_DEFAULT_REPO=workspace
FILEBAY_DEFAULT_BRANCH=main
FILEBAY_DEFAULT_MASKED_DIR=masked

# Desktop 回调配置（通知开通结果）
DESKTOP_API_BASE_URL=https://uat-desktop.cheersai.cloud
DESKTOP_INNER_API_KEY=replace-with-inner-api-key

# 是否启用回调通知 Desktop
BETA_NOTIFICATION_ENABLED=true
