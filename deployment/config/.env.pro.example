# Production environment variables for Nexus deployment

# Database / Redis / JWT
DB_PASSWORD=replace-with-pro-postgresql-password
REDIS_PASSWORD=
JWT_SECRET=replace-with-pro-jwt-secret

# Optional SMS
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=CheersAI
ALIYUN_SMS_TEMPLATE_CODE=

# Log level
LOG_LEVEL=INFO

# Beta provisioning pipeline
BETA_PROVISION_ENABLED=true
SSO_API_URL=https://sso.cheersai.cloud/api
SSO_PROVISION_OWNER=CheersAI
SSO_PROVISION_CLIENT_ID=replace-with-pro-client-id
SSO_PROVISION_CLIENT_SECRET=replace-with-pro-client-secret
SSO_PROVISION_DEFAULT_ROLE=desktop_team_admin

FILEBAY_BASE_URL=https://filebay.cheersai.cloud
FILEBAY_ADMIN_USERNAME=admin
FILEBAY_ADMIN_PASSWORD=replace-with-pro-filebay-admin-password
FILEBAY_DEFAULT_REPO=workspace
FILEBAY_DEFAULT_BRANCH=main
FILEBAY_DEFAULT_MASKED_DIR=masked

DESKTOP_API_BASE_URL=https://desktop.cheersai.cloud
DESKTOP_INNER_API_KEY=replace-with-pro-inner-api-key
BETA_NOTIFICATION_ENABLED=true
